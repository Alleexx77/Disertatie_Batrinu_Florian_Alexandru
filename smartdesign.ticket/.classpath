<?xml version="1.0" encoding="UTF-8"?>
<classpath>
	<classpathentry kind="src" path="app"/>
	<classpathentry combineaccessrules="false" kind="src" path="/smartdesign.base">
		<attributes>
			<attribute name="manifestderived" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry combineaccessrules="false" kind="src" path="/GlobalAppResources">
		<attributes>
			<attribute name="manifestderived" value="true"/>
		</attributes>
	</classpathentry>
	<classpathentry kind="output" path="bin"/>
</classpath>
