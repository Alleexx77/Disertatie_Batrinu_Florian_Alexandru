		on change(CAS_PERSOANA_RESPONSABILA) += `export async function onChangeCasPersoanaResponsabila(): Promise<void> {\n    const value = $do.CAS_PERSOANA_RESPONSABILA.get();\n    if (value) {\n        $do.CAS_ACCEPTARE_TICKET.set(null);\n    }\n}`
		on change(CAS_NECESAR_INTERVENTIE) += `export async function onChangeCasNecesarInterventie(): Promise<void> {\n    const value = $do.CAS_NECESAR_INTERVENTIE.get();\n    if (value === true) {\n        $do.CAS_DEPARTAMENT.set(\'Producator\');\n    }\n}`
