		on change(productLink) += `export async function onChangeProductLink(): Promise<void> {\n    if ($productLink) {\n        if ($do.GWSTICKETTYPE.get() === \'Preventiva\') {\n            $do.CAS_DEPARTAMENT.set($productLink.CAS_RESPDEPARTMENT.get());\n        }\n    }\n}`
