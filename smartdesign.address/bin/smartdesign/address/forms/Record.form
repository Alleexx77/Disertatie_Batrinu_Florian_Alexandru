namespace smartdesign.address

/* IMPORTANT: This is a generated file. Manual changes will disable automatic updates. */
@Derived(sha1="8aa14a38f010498794401b618524b38c7d34e127")
form Record {

	context {
		primary import do = DataObject(ADDRESS)
		dossierMD = DossierMassData()
		addressIdentitiesMD = DataObjectMassData(ADDRESS) {
			query {
				where = GWIDENTITYGUID = do.GWIDENTITYGUID AND GWIDENTITYGUID IS NOT NULL
			}
		}
		dossierMD2 = DossierMassData()

	}

	definitions {
		condition isAddressIdentitiesActive = `
			import { readProperty } from "smartdesign.base/property-access";
			export async function isAddressIdentitiesActive() {
				let value = await readProperty('AddressIdentityActive', 'Address');
				return value && value.toLowerCase() === "true";
			}
		`
	}

	events {
		@Inherited
		on change(CASWIDNR) += `
			import { onWIDNRChange } from "smartdesign.address/_formevents";
			onWIDNRChange($do);
		`
	}

	header = DefaultHeader {
		title = CONTACT
	}

	state read {

		fixedContent = ComponentSwitcher id:componentSwitcher {
			^content = RecordSummary id:businessCard {
				headline = Headline id:businessCardHeadline {
					title = ScriptedField id:businessCardTitle {
						expression = `
							import { getNameForCard } from "smartdesign.address/business-card";
							getNameForCard($do);
						`
					}
					subTitle = Field(FUNCTION)
					Badge businessCardHeadlineXRMBadge {
						color = `
							import { getColorForXRMType } from "smartdesign.address/business-card";
							getColorForXRMType($do, 'Mitarbeiter', 'Lieferant');
						`
						label = `$do.GWSTYPE.tryGet('')`
					}
				}
				HorizontalLayout businessCardMainLayout {
					LayoutColumn businessCardMainLayoutImageColumn {
						minWidth = 120
						maxWidth = 120
						ImageField businessCardImage {
							heightInPixels = 160
							autoHide = DISABLED
						}
					}
					LayoutColumn businessMainLayoutFormattedAddressContentColumn {
						minWidth = 200
						maxWidth = 440
						Group businessMainLayoutFormattedAddressContentGroup {
							ScriptedField businessMainLayoutFormattedAddressContentField {
								outputType = FORMATTED
								showCaption = false
								expression = `
									import { getFormattedAddressContent } from "smartdesign.address/business-card";
									getFormattedAddressContent($do);
								`
							}
							Field(LASTCONTACTUSER)
							Field(LASTCONTACTMEDIUM)
						}
					}
					LayoutColumn businessMainLayoutInformationColumn {
						minWidth = 200
						Group businessMainLayoutInformationGroup {
							StandardPhoneField businessMainLayoutInformationStandardPhoneField1 {
								iconName = "platform:field/phone"
							}
							StandardPhoneField businessMainLayoutInformationStandardPhoneField2 {
								kind = STANDARDPHONE2
								iconName = "platform:field/phone"
							}
							StandardEMailField businessMainLayoutInformationEMailField {
								iconName = "platform:field/e-mail"
							}
							ScriptedField businessMainLayoutInformationWebLinkField {
								outputType = URL
								iconName = "platform:field/www"
								caption = WEBSITE
								expression = `
									import { getWebLink } from "smartdesign.address/business-card";
									const link = getWebLink($do);
									link ? ScriptedField.url(link) : null;
								`
							}
							ScriptedField scriptedFieldGeneratedId1 {
								outputType = URL
								iconName = "WhatsApp"
								caption = SCRIPTEDFIELD_CAPTION_0
								expression = `ScriptedField.url(\n    \'https://api.whatsapp.com/send?phone=\' + encodeURIComponent(\n        $do.PHONEFIELDSTR2.get().replace(/\\s+/g, \'\')\n    ),\n    \"WhatsApp on: \" + $do.PHONEFIELDSTR2.get()\n);\n`
							}
							ScriptedField scriptedFieldGeneratedId2 {
								expression = `ScriptedField.url(\'https://www.linkedin.com/search/results/all/?keywords=\' + $do.CHRISTIANNAME.get() + \'%20\' + $do.NAME.get(), \"Search this person in LinkedIn\")`
								outputType = URL
								caption = SCRIPTEDFIELD_CAPTION_1
								iconName = "LinkedIn"
							}
						}
					}
				}
