namespace custom.opportunitylineitem

form LinkSearch {

	context {
		primary searchMassdata = DataObjectMassData(OPPORTUNITYLINEITEM)
		lastUsedMD = LastUsedMassData(OPPORTUNITYLINEITEM)
	}

	header = DefaultHeader {
		title = LINK_WITH_OPPORTUNITYLINEITEM
		contributionPoints = { }
	}

	state read {
		height = content
		VerticalLayout contentLayout {
			ratio = { 0, 1, 1 }
			SearchField searchField(searchResults) {
				hideTargetViewerWhenEmpty = true
				widgetsToHide = { recentlyUsed }
			}
			List searchResults {
				datasource = searchMassdata
				minVisibleItems = 8
			}
			EmbeddedList recentlyUsed {
				caption = RECENTLY_USED
				datasource = lastUsedMD
				extendedListEntryMode = HIDE
				entryAction = None
			}
		}
	}
}