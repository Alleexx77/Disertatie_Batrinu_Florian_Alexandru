							MailField(XFROM) {
								iconName = "platform:field/sender"
							}
							MailField(XTO) {
								iconName = "platform:field/arrow"
							}
							MailField(XCC)
						}
					}
					LayoutColumn headlineMainLayoutMiscDetailColumn {
						minWidth = 200
						Group headlineMainLayoutMiscDetailGroup {
							Field(EMAILSIZE)
							Field(HASATTACHMENTS)
							Field(CATEGORY)
						}
					}
				}
			}
			smallContent = RecordSummary id:recordSummaryReduced {
				headline = Headline id:headlineReduced {
					title = Field(SUBJECT)
					subTitle = Field(XFROM)
				}
			}
		}
		Parts parts {
			Part mainPart {
				caption = GENERAL_PART_LABEL
				enableJumpmarks = false
				VerticalLayout contentLayout {
					Group body {
						caption = BODY
						Field(BODY) {
							showCaption = false
						}
						actions = email_summary
					}
					Group notes {
						caption = NOTES
						Field(NOTES2) {
							showCaption = false
						}
					}
					ZLayout mainLayout {
						EmailAttachmentList attachments {
							caption = ATTACHMENTS
						}
						TagSelector tags {
						}
						Permissions permissions()
						PrimaryLinkedParentsList primaryLinks()
						EmbeddedList dossier {
							caption = DOSSIER
							datasource = dossierMD
						}
						ExtensionPoint defaultExtension {
							id = "record.default"
						}
						Group additionalInformation {
							caption = ADDITIONAL_INFORMATION
							ScriptedField insertInformation {
								caption = INSERT_INFORMATION_CAPTION
								expression = `
									import { getInsertInformation } from "smartdesign.base/additional-information";
									getInsertInformation($do);
								`
							}
							ScriptedField updateInformation {
								caption = UPDATE_INFORMATION_CAPTION
								expression = `
									import { getUpdateInformation } from "smartdesign.base/additional-information";
									getUpdateInformation($do);
								`
							}
						}
					}
				}
			}
			PartExtensionPoint defaultPartExtensionPoint {
				id = "record.part.default"
			}
		}
