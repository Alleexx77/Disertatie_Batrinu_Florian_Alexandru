		linkListAddress2 = LinkMassData(GWOPPORTUNITY => ADDRESS) {
			attributes = "SLCOMPETITOR"
			summary {
				caption = `\r\n\t\t\texport function computeCaption() {\r\n\t\t\t\tif ($current.GWISCOMPANY.get(false) && !$current.GWISCONTACT.get(false)) {\r\n\t\t\t\t\treturn Arrays.join([$current.COMPNAME.get(), $current.COMPNAME2.get()], \" \");\r\n\t\t\t\t} else {\r\n\t\t\t\t\tconst christianName = $current.CHRISTIANNAME.get();\r\n\t\t\t\t\tconst name = $current.NAME.get();\r\n\t\t\t\t\tconst addressTerm = $current.ADDRESSTERM.tryGet();\r\n\t\t\t\t\tconst title = $current.TITLE.tryGet();\r\n\t\t\t\t\tconst namePrefix = $current.GWNAMEPREFIX.tryGet();\r\n\r\n\t\t\t\t\tif (christianName && name) {\r\n\t\t\t\t\t\treturn Arrays.join([title, christianName, namePrefix, name], \" \");\r\n\t\t\t\t\t} else if (name) {\r\n\t\t\t\t\t\treturn Arrays.join([addressTerm, title, namePrefix, name], \" \");\r\n\t\t\t\t\t} else if (christianName) {\r\n\t\t\t\t\t\treturn christianName;\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t`
				description = `($current.GWISCOMPANY.get(false) && !$current.GWISCONTACT.get(false)) ? $current.TOWN1.get() : Arrays.join([$current.COMPNAME.get(), $current.GWBRANCH.get(),$current.TURNOVER.get(), $current.WWWFIELDSTR3.get()], \" \")`
