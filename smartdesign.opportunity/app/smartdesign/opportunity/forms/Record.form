	events {
		@Inherited
		on change(positions) += `
			export async function recomputeTotalAndGroupAmounts(): Promise<void> {
				const groups = new Map<string, DataObject.GWOPPORTUNITYPOS.Writable>();
				let totalAmount = BigNumber.ZERO;
				for await (const position of $positions) {
					if (position.ISGROUP.get(false)) {
						position.TOTALPRICE.set(BigNumber.ZERO);
						groups.set(position.GGUID.get(), position);
					} else if (!position.OPTIONALPOSITION.get(false)) {
						const positionAmount = position.TOTALPRICE.get(BigNumber.ZERO);
						addAmountToGroups(position, positionAmount, groups);
						totalAmount = totalAmount.plus(positionAmount);
					}
				}
				$do.OPPTOTALAMOUNT.set(totalAmount);
			}
			function addAmountToGroups(
				position: DataObject.GWOPPORTUNITYPOS.Writable,
				positionAmount: BigNumber,
				groups: Map<string, DataObject.GWOPPORTUNITYPOS.Writable>
			) {
				let current: DataObject.GWOPPORTUNITYPOS.Writable | undefined = position;
				while (current) {
					const group = groups.get(current.GROUPGUID.get());
					if (group) {
						group.TOTALPRICE.set(group.TOTALPRICE.get(BigNumber.ZERO).plus(positionAmount));
					}
					current = group;
				}
			}
		`
		on apply += `export async function onApply(): Promise<void> {\n  const lastChangeDateField = $do.CAS_DATAULTIMSCHIMBFAZA;\n  if ($do.DISTRIBUTIONPHASE.get()) {\n    const now = new Date();\n\n    // Convertim data în format \"YYYY-MM-DD HH:mm:ss\"\n    const formattedDate = now.toISOString().slice(0, 19).replace(\'T\', \' \');\n\n    // Setăm valoarea formatată în câmpul CAS_DATAULTIMSCHIMBFAZA\n    lastChangeDateField.set(now);\n  }\n  // Dacă DISTRIBUTIONPHASE are o valoare\n\n    const total = await $totalOpportunityLineItems.get();\n    $do.OPPTOTALAMOUNT.set(total ?? BigNumber.ZERO);\n\n    const totalMargin = await $totalNetMarign.get();\n$do.CAS_OFFERNETMARGIN.set(totalMargin ?? BigNumber.ZERO);\n\n}`
		on edit += `export async function onEdit(): Promise<void> {\n    if ($do.isNew()) {\n        $do.DISTRIBUTIONPHASE.set(\"Calificare\")\n        $do.CAS_PMRESPONSIBLE.set(\"Alexandru Batrinu\")\n    }\n    if($lnkedOPPROJ){\n        $do.CAS_PROJECTNAME.set($lnkedOPPROJ.KEYWORD.get())\n    }\n    if($lnkedOPPROJ)\n    {\n          $do.CAS_NUMARPROIECTCAS.set($lnkedOPPROJ.PRJNUMBER.get())\n    }\n    if($lnkedOPPROJ)\n    {\n        $do.CAS_PROJECTID.set($lnkedOPPROJ.GGUID.get())\n    }\n    if($do.DISTRIBUTIONPHASE.get()===\"Contractare\") $do.STATUS.set(\"Won\")\n}`
		on change(PERSONINCHARGE) += `export async function onChangePersonincharge(): Promise<void> {\n    const value = $do.PERSONINCHARGE.get();\n    \n}`
	}

