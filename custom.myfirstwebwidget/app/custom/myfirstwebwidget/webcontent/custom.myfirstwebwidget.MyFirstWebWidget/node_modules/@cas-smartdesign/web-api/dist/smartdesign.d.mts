type DateFormat = {
    /**
     * The format to be applied, the format is always separated with a dot `.` character.
     * The format consist of the following characters:
     * * `.` - Separator
     * * `d` - Day in month
     * * `M` - Month in year
     * * `y` - Year
     *
     * For formatting, the {@link DateFormat.dateSeparator} should be used.
     *
     * The amount of characters define the *minimum* amount of digits to be used for presenting the given field.
     *
     * @example "dd.MM.yyyy"
     * @example "yyyy.MM.dd"
     */
    format: string;
    /**
     * The date separator to be used.
     */
    dateSeparator: string;
};
type TimeFormat = {
    /**
     * The format to be applied.
     * * `:` - Separator
     * * `h` - Hour in 12 hour format
     * * `H` - Hour in 24 hour format
     * * `m` - Minute
     * * `s` - Second
     *
     * The amount of characters define the *minimum* amount of digits to be used for presenting the given field.
     *
     * @example "HH:mm:ss"
     * @example "hh:mm:ss"
     */
    format: string;
    /**
     * A flag which indicates whether the given format is using 12 hour format.
     */
    isTwelveHoursFormat: boolean;
};
type NumberFormat = {
    /**
     * Symbol to be used to separate the integer part from the fractional part of a number.
     */
    decimalSeparator: string;
    /**
     * Symbol to be used to separate groups of digits.
     */
    groupingSeparator: string;
};
