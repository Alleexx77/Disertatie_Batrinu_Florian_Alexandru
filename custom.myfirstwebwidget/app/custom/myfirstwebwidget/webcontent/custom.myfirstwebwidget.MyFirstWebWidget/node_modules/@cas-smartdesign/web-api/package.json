{
  "name": "@cas-smartdesign/web-api",
  "version": "5.9.0",
  "description": "Web app integration framework for SmartDesign",
  "main": "dist/smartdesign.cjs",
  "module": "dist/smartdesign.mjs",
  "types": "dist/smartdesign.d.ts",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@swc/core": "^1.13.5",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^18.0.1",
    "tsup": "^8.5.1",
    "vitest": "^4.0.18",
    "vitest-fetch-mock": "^0.4.5",
    "@cas-smartdesign/license-generator": "^1.9.0",
    "@cas-smartdesign/design-tokens": "^1.9.0"
  },
  "files": [
    "dist",
    "npm-third-party-licenses.json"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "version": "pnpm version",
    "build:no-license": "tsc --noEmit && tsup",
    "build": "pnpm generate-license && pnpm build:no-license",
    "test": "vitest --run",
    "test:watch": "vitest",
    "generate-license": "sd-license-generator --r ../"
  }
}